#!/usr/bin/env bash
set -euo pipefail

PROFILES_DIR="$HOME/.config/new-project"
PROFILES_FILE="$PROFILES_DIR/profiles"

# ─── dependency check ────────────────────────────────────────────────────────
for cmd in git gh gum; do
  if ! command -v "$cmd" &>/dev/null; then
    printf "error: '%s' is required but not installed.\n" "$cmd" >&2
    [[ "$cmd" == "gum" ]] && printf "  brew install gum\n" >&2
    exit 1
  fi
done

# ─── header ──────────────────────────────────────────────────────────────────
gum style \
  --foreground 212 --border-foreground 212 --border double \
  --align center --width 52 --margin "1 2" --padding "1 4" \
  "◆ new-project" "Bootstrap a repo in seconds"

# ─── project name + dir ──────────────────────────────────────────────────────
PROJECT_NAME=$(gum input \
  --prompt "  Project name › " \
  --placeholder "my-app")
[[ -z "$PROJECT_NAME" ]] && gum style --foreground 196 "  Aborted: project name is required." && exit 1

PARENT_DIR=$(gum file --directory --file=false \
  --header "  Parent directory" \
  "$HOME")
PARENT_DIR="${PARENT_DIR%/}"
PROJECT_PATH="$PARENT_DIR/$PROJECT_NAME"

# ─── identity: saved profiles ────────────────────────────────────────────────
mkdir -p "$PROFILES_DIR"

save_profile() {
  local label="$1" name="$2" email="$3"
  # remove existing entry with same label, then append
  grep -v "^${label}|" "$PROFILES_FILE" > "${PROFILES_FILE}.tmp" 2>/dev/null || true
  mv "${PROFILES_FILE}.tmp" "$PROFILES_FILE" 2>/dev/null || true
  echo "${label}|${name}|${email}" >> "$PROFILES_FILE"
}

load_profile() {
  local label="$1"
  local line
  line=$(grep "^${label}|" "$PROFILES_FILE")
  GIT_NAME=$(echo "$line" | cut -d'|' -f2)
  GIT_EMAIL=$(echo "$line" | cut -d'|' -f3)
}

if [[ -f "$PROFILES_FILE" ]] && [[ -s "$PROFILES_FILE" ]]; then
  PROFILE_CHOICE=$(
    {
      cut -d'|' -f1 "$PROFILES_FILE"
      echo "+ New profile"
    } | gum choose --header "  Identity"
  )

  if [[ "$PROFILE_CHOICE" == "+ New profile" ]]; then
    GIT_NAME=$(gum input --prompt "  git user.name › " --placeholder "Your Name")
    GIT_EMAIL=$(gum input --prompt "  git user.email › " --placeholder "you@example.com")
    PROFILE_LABEL=$(gum input --prompt "  Save as › " --placeholder "work / personal")
    [[ -n "$PROFILE_LABEL" ]] && save_profile "$PROFILE_LABEL" "$GIT_NAME" "$GIT_EMAIL"
  else
    load_profile "$PROFILE_CHOICE"
  fi
else
  GIT_NAME=$(gum input --prompt "  git user.name › " --placeholder "Your Name")
  GIT_EMAIL=$(gum input --prompt "  git user.email › " --placeholder "you@example.com")
  PROFILE_LABEL=$(gum input --prompt "  Save as profile (optional) › " --placeholder "work / personal")
  [[ -n "$PROFILE_LABEL" ]] && save_profile "$PROFILE_LABEL" "$GIT_NAME" "$GIT_EMAIL"
fi

# ─── stack ───────────────────────────────────────────────────────────────────
STACK=$(gum choose \
  --header "  Tech stack" \
  "Node.js" "TypeScript" "Python" "Go" "Rust" "React / Next.js" "Bare" "From template →")

TEMPLATE_REPO=""
if [[ "$STACK" == "From template →" ]]; then
  TEMPLATE_REPO=$(gum input \
    --prompt "  GitHub template › " \
    --placeholder "owner/repo")
  [[ -z "$TEMPLATE_REPO" ]] && gum style --foreground 196 "  Aborted: template repo required." && exit 1
fi

# ─── license ─────────────────────────────────────────────────────────────────
LICENSE="None"
if [[ "$STACK" != "From template →" ]]; then
  LICENSE=$(gum choose --header "  License" "MIT" "Apache 2.0" "GPL-3.0" "None")
fi

# ─── branch name ─────────────────────────────────────────────────────────────
BRANCH=$(gum input --prompt "  Default branch › " --value "main")
BRANCH="${BRANCH:-main}"

# ─── .env.example ────────────────────────────────────────────────────────────
ADD_ENV=false
if [[ "$STACK" != "From template →" ]]; then
  gum confirm "  Add .env.example?" && ADD_ENV=true || true
fi

# ─── visibility + description ────────────────────────────────────────────────
VISIBILITY=$(gum choose --header "  Visibility" "private" "public")

DESCRIPTION=$(gum input \
  --prompt "  Description (optional) › " \
  --placeholder "What does this project do?")

# ─── summary + confirm ───────────────────────────────────────────────────────
echo ""
gum style --foreground 240 \
  "  Project    $PROJECT_NAME" \
  "  Path       $PROJECT_PATH" \
  "  Identity   $GIT_NAME <$GIT_EMAIL>" \
  "  Stack      $STACK${TEMPLATE_REPO:+ ($TEMPLATE_REPO)}" \
  "  License    $LICENSE" \
  "  Branch     $BRANCH" \
  "  GitHub     $VISIBILITY"
echo ""
gum confirm "  Create project?" || { echo "  Aborted."; exit 0; }
echo ""

# ─── guard ───────────────────────────────────────────────────────────────────
if [[ -d "$PROJECT_PATH" ]]; then
  gum style --foreground 196 "  Error: '$PROJECT_PATH' already exists."
  exit 1
fi

# ─── helpers ─────────────────────────────────────────────────────────────────
GITHUB_USER=$(gh api user --jq .login 2>/dev/null || echo "username")
YEAR=$(date +%Y)
LICENSE_SPDX="${LICENSE/None/UNLICENSED}"
LICENSE_SPDX="${LICENSE_SPDX/ /-}"   # "Apache 2.0" → "Apache-2.0"

write_readme() {
  cat > README.md <<EOF
# $PROJECT_NAME

${DESCRIPTION:-}
EOF
}

write_env_example() {
  $ADD_ENV || return 0
  cat > .env.example <<'EOF'
# Copy to .env and fill in values
# cp .env.example .env

EOF
}

write_license() {
  case "$LICENSE" in
    "MIT")
      cat > LICENSE <<EOF
MIT License

Copyright (c) $YEAR $GIT_NAME

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.
EOF
      ;;
    "Apache 2.0")
      cat > LICENSE <<EOF
Copyright $YEAR $GIT_NAME

Licensed under the Apache License, Version 2.0 (the "License");
you may not use this file except in compliance with the License.
You may obtain a copy of the License at

    http://www.apache.org/licenses/LICENSE-2.0

Unless required by applicable law or agreed to in writing, software
distributed under the License is distributed on an "AS IS" BASIS,
WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
See the License for the specific language governing permissions and
limitations under the License.
EOF
      ;;
    "GPL-3.0")
      cat > LICENSE <<EOF
Copyright (C) $YEAR $GIT_NAME

This program is free software: you can redistribute it and/or modify
it under the terms of the GNU General Public License as published by
the Free Software Foundation, either version 3 of the License, or
(at your option) any later version.

This program is distributed in the hope that it will be useful,
but WITHOUT ANY WARRANTY; without even the implied warranty of
MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
GNU General Public License for more details.

You should have received a copy of the GNU General Public License
along with this program. If not, see <https://www.gnu.org/licenses/>.
EOF
      ;;
  esac
}

# ─── template flow ───────────────────────────────────────────────────────────
if [[ "$STACK" == "From template →" ]]; then
  mkdir -p "$PARENT_DIR"
  cd "$PARENT_DIR"

  GH_ARGS=("$PROJECT_NAME" "--template" "$TEMPLATE_REPO" "--$VISIBILITY" "--clone")
  [[ -n "$DESCRIPTION" ]] && GH_ARGS+=("--description" "$DESCRIPTION")

  gum spin --spinner dot --title "  Creating from template..." -- \
    gh repo create "${GH_ARGS[@]}"

  cd "$PROJECT_PATH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"
  [[ "$BRANCH" != "main" ]] && git branch -m "$BRANCH"

# ─── standard flow ───────────────────────────────────────────────────────────
else
  mkdir -p "$PROJECT_PATH"
  cd "$PROJECT_PATH"
  git init -q -b "$BRANCH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"

  case "$STACK" in
    "Node.js")
      cat > .gitignore <<'EOF'
node_modules/
dist/
.env
.env.local
*.log
.DS_Store
EOF
      cat > package.json <<EOF
{
  "name": "$PROJECT_NAME",
  "version": "0.1.0",
  "description": "$DESCRIPTION",
  "main": "index.js",
  "scripts": {
    "start": "node index.js"
  },
  "license": "$LICENSE_SPDX"
}
EOF
      touch index.js
      write_readme; write_env_example; write_license
      ;;

    "TypeScript")
      cat > .gitignore <<'EOF'
node_modules/
dist/
.env
.env.local
*.log
.DS_Store
EOF
      cat > package.json <<EOF
{
  "name": "$PROJECT_NAME",
  "version": "0.1.0",
  "description": "$DESCRIPTION",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "@types/node": "^20.0.0"
  },
  "license": "$LICENSE_SPDX"
}
EOF
      cat > tsconfig.json <<'EOF'
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
EOF
      mkdir -p src
      cat > src/index.ts <<'EOF'
function main(): void {
  console.log("Hello, world!");
}

main();
EOF
      write_readme; write_env_example; write_license
      ;;

    "Python")
      cat > .gitignore <<'EOF'
venv/
.venv/
__pycache__/
*.pyc
*.pyo
.env
.env.local
dist/
*.egg-info/
.pytest_cache/
.DS_Store
EOF
      touch requirements.txt
      cat > main.py <<'EOF'
def main() -> None:
    print("Hello, world!")


if __name__ == "__main__":
    main()
EOF
      write_readme; write_env_example; write_license
      ;;

    "Go")
      cat > .gitignore <<'EOF'
bin/
*.exe
*.test
.env
.DS_Store
EOF
      cat > go.mod <<EOF
module github.com/$GITHUB_USER/$PROJECT_NAME

go 1.22
EOF
      cat > main.go <<'EOF'
package main

import "fmt"

func main() {
	fmt.Println("Hello, world!")
}
EOF
      write_readme; write_env_example; write_license
      ;;

    "Rust")
      cat > .gitignore <<'EOF'
/target
.env
.DS_Store
EOF
      write_readme; write_env_example; write_license
      gum style --foreground 214 "  Note: run 'cargo init .' to scaffold Rust boilerplate"
      ;;

    "React / Next.js")
      cat > .gitignore <<'EOF'
node_modules/
.next/
out/
.env
.env.local
.env*.local
*.log
.DS_Store
EOF
      write_readme; write_env_example; write_license
      gum style --foreground 214 "  Note: run 'npx create-next-app@latest .' to scaffold"
      ;;

    "Bare")
      cat > .gitignore <<'EOF'
.env
.env.local
.DS_Store
EOF
      write_readme; write_env_example; write_license
      ;;
  esac

  git add .
  git commit -q -m "init: bootstrap $PROJECT_NAME"

  GH_ARGS=("$PROJECT_NAME" "--$VISIBILITY" "--source=." "--remote=origin" "--push")
  [[ -n "$DESCRIPTION" ]] && GH_ARGS+=("--description" "$DESCRIPTION")

  gum spin --spinner dot --title "  Creating GitHub repo..." -- \
    gh repo create "${GH_ARGS[@]}"
fi

# ─── open in editor ──────────────────────────────────────────────────────────
EDITOR_CHOICE=$(gum choose --header "  Open in editor" \
  "VS Code" "Cursor" "Zed" "Neovim" "Skip")

case "$EDITOR_CHOICE" in
  "VS Code")  code "$PROJECT_PATH" ;;
  "Cursor")   cursor "$PROJECT_PATH" ;;
  "Zed")      zed "$PROJECT_PATH" ;;
  "Neovim")   nvim "$PROJECT_PATH" ;;
esac

# ─── done ────────────────────────────────────────────────────────────────────
REPO_URL=$(gh repo view "$PROJECT_NAME" --json url --jq .url 2>/dev/null || echo "")

echo ""
gum style \
  --foreground 82 --border-foreground 82 --border rounded \
  --padding "0 2" --margin "0 2" \
  "✓ $PROJECT_NAME is ready${REPO_URL:+  →  $REPO_URL}"
echo ""
gum style --foreground 240 "  cd $PROJECT_PATH"
echo ""
