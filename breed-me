#!/usr/bin/env bash
set -euo pipefail

# ─── config ───────────────────────────────────────────────────────────────────
CONFIG_DIR="$HOME/.config/breed-me"
PROFILES_FILE="$CONFIG_DIR/profiles"
HISTORY_FILE="$CONFIG_DIR/history"
LAST_DIR_FILE="$CONFIG_DIR/last_dir"
SELF_REPO="unlocalhosted/breed-me-an-app"
SELF_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

mkdir -p "$CONFIG_DIR"

# ─── cleanup ──────────────────────────────────────────────────────────────────
TMPFILES=()
cleanup() { rm -f "${TMPFILES[@]}" 2>/dev/null || true; }
trap cleanup EXIT INT TERM

# ─── helpers ──────────────────────────────────────────────────────────────────
safe_timeout() {
  if command -v timeout &>/dev/null; then timeout "$@"
  elif command -v gtimeout &>/dev/null; then gtimeout "$@"
  else shift; "$@"
  fi
}

# ─── --help ───────────────────────────────────────────────────────────────────
show_help() {
  printf "Usage: breed-me [SUBCOMMAND] [OPTIONS]\n\n"
  printf "Subcommands:\n"
  printf "  list        Show previously created projects\n\n"
  printf "Options:\n"
  printf "  --local     Skip all GitHub steps (no gh required)\n"
  printf "  --dry-run   Preview inputs without creating anything\n"
  printf "  --update    Update to the latest version\n"
  printf "  -h, --help  Show this help\n"
}

# ─── --update ─────────────────────────────────────────────────────────────────
do_update() {
  local tmp
  tmp=$(mktemp); TMPFILES+=("$tmp")
  printf "Updating breed-me...\n"
  curl -fsSL --max-time 30 \
    "https://raw.githubusercontent.com/$SELF_REPO/main/breed-me" \
    -o "$tmp" || { printf "error: download failed\n" >&2; exit 1; }
  if [[ -w "$SELF_PATH" ]]; then
    install -m 755 "$tmp" "$SELF_PATH"
  elif command -v sudo &>/dev/null; then
    sudo install -m 755 "$tmp" "$SELF_PATH"
  else
    printf "error: cannot write to %s\n  Try: sudo breed-me --update\n" "$SELF_PATH" >&2
    exit 1
  fi
  printf "Done. You are on the latest version.\n"
  exit 0
}

# ─── flags + subcommand ───────────────────────────────────────────────────────
FLAG_LOCAL=false
FLAG_DRY_RUN=false
SUBCOMMAND=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --local)    FLAG_LOCAL=true ;;
    --dry-run)  FLAG_DRY_RUN=true ;;
    --update)   do_update ;;
    -h|--help)  show_help; exit 0 ;;
    list)       SUBCOMMAND="list" ;;
    *)          printf "error: unknown option: %s\n" "$1" >&2; exit 1 ;;
  esac
  shift
done

# ─── dep check ────────────────────────────────────────────────────────────────
for cmd in git gum; do
  command -v "$cmd" &>/dev/null || {
    printf "error: '%s' is required. brew install %s\n" "$cmd" "$cmd" >&2
    exit 1
  }
done
if [[ "$FLAG_LOCAL" == false ]] && ! command -v gh &>/dev/null; then
  printf "error: 'gh' is required for GitHub. brew install gh\n" >&2
  printf "       Or use --local to skip GitHub.\n" >&2
  exit 1
fi

# ─── list subcommand ──────────────────────────────────────────────────────────
if [[ "$SUBCOMMAND" == "list" ]]; then
  if [[ ! -f "$HISTORY_FILE" ]] || [[ ! -s "$HISTORY_FILE" ]]; then
    gum style --foreground 240 "  No projects yet."
    exit 0
  fi
  echo ""
  while IFS='|' read -r pname ppath purl pdate; do
    gum style --foreground 212 "  $pname"
    gum style --foreground 240 \
      "    path  $ppath" \
      "    repo  ${purl:-local}" \
      "    date  $pdate"
    echo ""
  done < "$HISTORY_FILE"
  exit 0
fi

# ─── header ───────────────────────────────────────────────────────────────────
gum style \
  --foreground 212 --border-foreground 212 --border double \
  --align center --width 52 --margin "1 2" --padding "1 4" \
  "◆ breed-me" "Bootstrap a repo in seconds"

# ─── prefetch github data ─────────────────────────────────────────────────────
GITHUB_USER=""
GITHUB_ORGS=""

if [[ "$FLAG_LOCAL" == false ]]; then
  PREFETCH_TMP=$(mktemp); TMPFILES+=("$PREFETCH_TMP")

  gum spin --spinner dot --title "  Connecting to GitHub..." -- \
    bash -c "
      safe_timeout() {
        if command -v timeout &>/dev/null; then timeout \"\$@\"
        elif command -v gtimeout &>/dev/null; then gtimeout \"\$@\"
        else shift; \"\$@\"; fi
      }
      safe_timeout 10 gh api user --jq .login > '$PREFETCH_TMP' 2>/dev/null || true
      safe_timeout 10 gh api user/orgs --jq '.[].login' >> '$PREFETCH_TMP' 2>/dev/null || true
    " || true

  if [[ -s "$PREFETCH_TMP" ]]; then
    GITHUB_USER=$(head -1 "$PREFETCH_TMP")
    GITHUB_ORGS=$(tail -n +2 "$PREFETCH_TMP")
  fi

  if [[ -z "$GITHUB_USER" ]]; then
    gum style --foreground 196 \
      "  GitHub auth failed. Run: gh auth login" \
      "  Or use --local to skip GitHub."
    exit 1
  fi
fi

# ─── project name ─────────────────────────────────────────────────────────────
PROJECT_NAME_RAW=$(gum input --prompt "  Project name › " --placeholder "my-app")
[[ -z "$PROJECT_NAME_RAW" ]] && \
  gum style --foreground 196 "  Aborted: name is required." && exit 1

PROJECT_NAME=$(printf "%s" "$PROJECT_NAME_RAW" \
  | tr '[:upper:]' '[:lower:]' \
  | tr ' _' '-' \
  | tr -cd 'a-z0-9-')

# strip leading/trailing hyphens (e.g. "--my-app" → "my-app")
PROJECT_NAME="${PROJECT_NAME#"${PROJECT_NAME%%[!-]*}"}"
PROJECT_NAME="${PROJECT_NAME%"${PROJECT_NAME##*[!-]}"}"

# enforce GitHub's 100-char repo name limit
if [[ ${#PROJECT_NAME} -gt 100 ]]; then
  PROJECT_NAME="${PROJECT_NAME:0:100}"
  PROJECT_NAME="${PROJECT_NAME%%-}"   # don't end on a hyphen after truncation
fi

if [[ "$PROJECT_NAME" != "$PROJECT_NAME_RAW" ]]; then
  gum style --foreground 214 "  Name normalized: $PROJECT_NAME_RAW → $PROJECT_NAME"
fi
[[ -z "$PROJECT_NAME" ]] && \
  gum style --foreground 196 "  Aborted: name is empty after normalization." && exit 1

# ─── parent directory ─────────────────────────────────────────────────────────
DEFAULT_DIR="$HOME"
if [[ -f "$LAST_DIR_FILE" ]]; then
  SAVED_DIR=$(cat "$LAST_DIR_FILE")
  [[ -d "$SAVED_DIR" ]] && DEFAULT_DIR="$SAVED_DIR"
fi

PARENT_DIR=$(gum file --directory --file=false \
  --header "  Parent directory" \
  "$DEFAULT_DIR") || { gum style --foreground 196 "  Aborted."; exit 1; }
[[ -z "$PARENT_DIR" ]] && gum style --foreground 196 "  Aborted: no directory selected." && exit 1
PARENT_DIR="${PARENT_DIR%/}"
printf "%s\n" "$PARENT_DIR" > "$LAST_DIR_FILE"

PROJECT_PATH="$PARENT_DIR/$PROJECT_NAME"

# ─── identity: saved profiles ─────────────────────────────────────────────────
save_profile() {
  local label="${1//|/}" name="$2" email="$3"
  # use awk for exact field match — grep regex would misinterpret label chars like . * [
  awk -F'|' -v l="$label" '$1 != l' "$PROFILES_FILE" > "${PROFILES_FILE}.tmp" 2>/dev/null || true
  mv "${PROFILES_FILE}.tmp" "$PROFILES_FILE" 2>/dev/null || true
  printf "%s|%s|%s\n" "$label" "$name" "$email" >> "$PROFILES_FILE"
}

load_profile() {
  local label="$1" line
  # awk exits 0 even on no match, avoiding set -e issues with grep's exit 1
  line=$(awk -F'|' -v l="$label" '$1 == l {print; exit}' "$PROFILES_FILE" 2>/dev/null || true)
  GIT_NAME=$(cut -d'|' -f2 <<< "$line")
  GIT_EMAIL=$(cut -d'|' -f3 <<< "$line")
}

GIT_NAME=""
GIT_EMAIL=""

if [[ -f "$PROFILES_FILE" ]] && [[ -s "$PROFILES_FILE" ]]; then
  PROFILE_CHOICE=$(
    { cut -d'|' -f1 "$PROFILES_FILE"; printf "+ New profile\n"; } \
    | gum choose --header "  Identity"
  )
  if [[ "$PROFILE_CHOICE" == "+ New profile" ]]; then
    GIT_NAME=$(gum input --prompt "  git user.name › " --placeholder "Your Name")
    GIT_EMAIL=$(gum input --prompt "  git user.email › " --placeholder "you@example.com")
    PROFILE_LABEL=$(gum input --prompt "  Save as › " --placeholder "work / personal")
    PROFILE_LABEL="${PROFILE_LABEL//|/}"
    [[ -n "$PROFILE_LABEL" ]] && save_profile "$PROFILE_LABEL" "$GIT_NAME" "$GIT_EMAIL"
  else
    load_profile "$PROFILE_CHOICE"
  fi
else
  GIT_NAME=$(gum input --prompt "  git user.name › " --placeholder "Your Name")
  GIT_EMAIL=$(gum input --prompt "  git user.email › " --placeholder "you@example.com")
  PROFILE_LABEL=$(gum input --prompt "  Save as profile (optional) › " --placeholder "work / personal")
  PROFILE_LABEL="${PROFILE_LABEL//|/}"
  [[ -n "$PROFILE_LABEL" ]] && save_profile "$PROFILE_LABEL" "$GIT_NAME" "$GIT_EMAIL"
fi

[[ -z "$GIT_NAME" ]]  && gum style --foreground 196 "  Name is required." && exit 1
[[ -z "$GIT_EMAIL" ]] && gum style --foreground 196 "  Email is required." && exit 1

# ─── stack ────────────────────────────────────────────────────────────────────
STACK_OPTIONS=("Node.js" "TypeScript" "Python" "Go" "Rust" "React / Next.js" "Bare")
[[ "$FLAG_LOCAL" == false ]] && STACK_OPTIONS+=("From template →")

STACK=$(printf "%s\n" "${STACK_OPTIONS[@]}" | gum choose --header "  Tech stack")

TEMPLATE_REPO=""
if [[ "$STACK" == "From template →" ]]; then
  TEMPLATE_REPO=$(gum input --prompt "  GitHub template › " --placeholder "owner/repo")
  [[ -z "$TEMPLATE_REPO" ]] && \
    gum style --foreground 196 "  Aborted: template repo required." && exit 1
fi

# ─── license ──────────────────────────────────────────────────────────────────
LICENSE="None"
[[ "$STACK" != "From template →" ]] && \
  LICENSE=$(gum choose --header "  License" "MIT" "Apache 2.0" "GPL-3.0" "None")

# ─── branch name ──────────────────────────────────────────────────────────────
while true; do
  BRANCH=$(gum input --prompt "  Default branch › " --value "main")
  BRANCH="${BRANCH:-main}"
  if [[ "$BRANCH" =~ \.\. ]] \
     || [[ "$BRANCH" =~ [[:space:]] ]] \
     || [[ ! "$BRANCH" =~ ^[a-zA-Z0-9/_.-]+$ ]]; then
    gum style --foreground 196 "  Invalid branch name. Use [a-zA-Z0-9/_.-], no spaces or '..'."
  else
    break
  fi
done

# ─── .env.example ─────────────────────────────────────────────────────────────
ADD_ENV=false
[[ "$STACK" != "From template →" ]] && \
  { gum confirm "  Add .env.example?" && ADD_ENV=true || true; }

# ─── github actions ci ────────────────────────────────────────────────────────
ADD_CI=false
if [[ "$STACK" != "From template →" ]] && [[ "$STACK" != "Bare" ]]; then
  gum confirm "  Add GitHub Actions CI?" && ADD_CI=true || true
fi

# ─── push to github ───────────────────────────────────────────────────────────
PUSH_TO_GITHUB=false
OWNER="${GITHUB_USER}"
VISIBILITY="private"
DESCRIPTION=""

if [[ "$FLAG_LOCAL" == true ]]; then
  PUSH_TO_GITHUB=false
elif [[ "$STACK" == "From template →" ]]; then
  PUSH_TO_GITHUB=true
else
  gum confirm "  Push to GitHub?" && PUSH_TO_GITHUB=true || true
fi

if [[ "$PUSH_TO_GITHUB" == true ]]; then
  if [[ -n "$GITHUB_ORGS" ]]; then
    OWNER=$(printf "%s\n%s\n" "$GITHUB_USER" "$GITHUB_ORGS" | gum choose --header "  Push to")
  else
    OWNER="$GITHUB_USER"
  fi
  VISIBILITY=$(gum choose --header "  Visibility" "private" "public")
fi

DESCRIPTION=$(gum input \
  --prompt "  Description (optional) › " \
  --placeholder "What does this project do?")

# ─── summary ──────────────────────────────────────────────────────────────────
echo ""
gum style --foreground 240 \
  "  Project    $PROJECT_NAME" \
  "  Path       $PROJECT_PATH" \
  "  Identity   $GIT_NAME <$GIT_EMAIL>" \
  "  Stack      $STACK${TEMPLATE_REPO:+ ($TEMPLATE_REPO)}" \
  "  License    $LICENSE" \
  "  Branch     $BRANCH" \
  "  CI         $(if $ADD_CI; then printf yes; else printf no; fi)"

if [[ "$PUSH_TO_GITHUB" == true ]]; then
  gum style --foreground 240 \
    "  Owner      $OWNER" \
    "  GitHub     $VISIBILITY"
else
  gum style --foreground 240 "  GitHub     local only"
fi
echo ""

if [[ "$FLAG_DRY_RUN" == true ]]; then
  gum style --foreground 214 --border rounded --border-foreground 214 \
    --padding "0 2" --margin "0 2" \
    "--dry-run: nothing was created."
  echo ""
  exit 0
fi

gum confirm "  Create project?" || { printf "  Aborted.\n"; exit 0; }
echo ""

# ─── guard ────────────────────────────────────────────────────────────────────
if [[ -d "$PROJECT_PATH" ]]; then
  gum style --foreground 196 "  Error: '$PROJECT_PATH' already exists."
  exit 1
fi

# ─── write helpers ────────────────────────────────────────────────────────────
YEAR=$(date +%Y)
LICENSE_SPDX="${LICENSE/None/UNLICENSED}"
LICENSE_SPDX="${LICENSE_SPDX/ /-}"
# JSON-safe description: escape backslashes then double quotes
JSON_DESCRIPTION="${DESCRIPTION//\\/\\\\}"
JSON_DESCRIPTION="${JSON_DESCRIPTION//\"/\\\"}"

write_readme() {
  cat > README.md <<EOF
# $PROJECT_NAME

${DESCRIPTION:-}
EOF
}

write_env_example() {
  $ADD_ENV || return 0
  cat > .env.example <<'EOF'
# Copy to .env and fill in values
# cp .env.example .env

EOF
}

write_license() {
  case "$LICENSE" in
    "MIT")
      cat > LICENSE <<EOF
MIT License

Copyright (c) $YEAR $GIT_NAME

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.
EOF
      ;;
    "Apache 2.0")
      cat > LICENSE <<EOF
Copyright $YEAR $GIT_NAME

Licensed under the Apache License, Version 2.0 (the "License");
you may not use this file except in compliance with the License.
You may obtain a copy of the License at

    http://www.apache.org/licenses/LICENSE-2.0

Unless required by applicable law or agreed to in writing, software
distributed under the License is distributed on an "AS IS" BASIS,
WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
See the License for the specific language governing permissions and
