      ;;
  esac
}

write_ci() {
  $ADD_CI || return 0
  mkdir -p .github/workflows
  case "$STACK" in
    "Node.js")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 20 }
      - run: npm install
      - run: npm test --if-present
EOF
      ;;
    "TypeScript")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 20 }
      - run: npm install
      - run: npm run build
      - run: npm test --if-present
EOF
      ;;
    "Python")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: "3.12" }
      - run: pip install -r requirements.txt
      - run: python -m pytest --tb=short -q
EOF
      ;;
    "Go")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with: { go-version: stable }
      - run: go build ./...
      - run: go test ./...
EOF
      ;;
    "Rust")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
      - run: cargo build
      - run: cargo test
EOF
      ;;
    "React / Next.js")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 20 }
      - run: npm install
      - run: npm run build
EOF
      ;;
  esac
}

# ─── template flow ────────────────────────────────────────────────────────────
if [[ "$STACK" == "From template →" ]]; then
  mkdir -p "$PARENT_DIR"
  cd "$PARENT_DIR"

  GH_ARGS=("$OWNER/$PROJECT_NAME" "--template" "$TEMPLATE_REPO" "--$VISIBILITY" "--clone")
  [[ -n "$DESCRIPTION" ]] && GH_ARGS+=("--description" "$DESCRIPTION")

  gum spin --spinner dot --title "  Creating from template..." -- \
    gh repo create "${GH_ARGS[@]}"

  cd "$PROJECT_PATH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"

  if [[ "$BRANCH" != "main" ]]; then
    git branch -m "$BRANCH"
    git push origin "$BRANCH"
    gh repo edit "$OWNER/$PROJECT_NAME" --default-branch "$BRANCH" 2>/dev/null || true
  fi

# ─── standard flow ────────────────────────────────────────────────────────────
else
  mkdir -p "$PROJECT_PATH" || {
    gum style --foreground 196 "  Error: cannot create '$PROJECT_PATH'. Check permissions."
    exit 1
  }
  cd "$PROJECT_PATH"
  git init -q -b "$BRANCH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"

  # Go module path: full github path when pushing, plain name when local-only
  GO_MODULE="${OWNER:+github.com/$OWNER/}$PROJECT_NAME"

  case "$STACK" in
    "Node.js")
      cat > .gitignore <<'EOF'
node_modules/
dist/
.env
.env.local
*.log
.DS_Store
EOF
      cat > package.json <<EOF
{
  "name": "$PROJECT_NAME",
  "version": "0.1.0",
  "description": "$JSON_DESCRIPTION",
  "main": "index.js",
  "scripts": {
    "start": "node index.js"
  },
  "license": "$LICENSE_SPDX"
}
EOF
      touch index.js
      write_readme; write_env_example; write_license; write_ci
      ;;

    "TypeScript")
      cat > .gitignore <<'EOF'
node_modules/
dist/
.env
.env.local
*.log
.DS_Store
EOF
      cat > package.json <<EOF
{
  "name": "$PROJECT_NAME",
  "version": "0.1.0",
  "description": "$JSON_DESCRIPTION",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "@types/node": "^20.0.0"
  },
  "license": "$LICENSE_SPDX"
}
EOF
      cat > tsconfig.json <<'EOF'
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
EOF
      mkdir -p src
      cat > src/index.ts <<'EOF'
function main(): void {
  console.log("Hello, world!");
}

main();
EOF
      write_readme; write_env_example; write_license; write_ci
      ;;

    "Python")
      cat > .gitignore <<'EOF'
venv/
.venv/
__pycache__/
*.pyc
*.pyo
.env
.env.local
dist/
*.egg-info/
.pytest_cache/
.DS_Store
EOF
      touch requirements.txt
      cat > main.py <<'EOF'
def main() -> None:
    print("Hello, world!")


if __name__ == "__main__":
    main()
EOF
      write_readme; write_env_example; write_license; write_ci
      ;;

    "Go")
      cat > .gitignore <<'EOF'
bin/
*.exe
*.test
.env
.DS_Store
EOF
      cat > go.mod <<EOF
module $GO_MODULE

go 1.22
EOF
      cat > main.go <<'EOF'
package main

import "fmt"

func main() {
	fmt.Println("Hello, world!")
}
EOF
      write_readme; write_env_example; write_license; write_ci
      ;;

    "Rust")
      cat > .gitignore <<'EOF'
/target
.env
.DS_Store
EOF
      write_readme; write_env_example; write_license; write_ci
      if command -v cargo &>/dev/null; then
        cargo init . --name "$PROJECT_NAME" -q 2>/dev/null || true
      else
        gum style --foreground 214 "  Note: 'cargo' not found. Install Rust then run: cargo init ."
      fi
      ;;

    "React / Next.js")
      cat > .gitignore <<'EOF'
node_modules/
.next/
out/
.env
.env.local
.env*.local
*.log
.DS_Store
EOF
      write_readme; write_env_example; write_license; write_ci
      gum style --foreground 214 "  Note: run 'npx create-next-app@latest .' to scaffold"
      ;;

    "Bare")
      cat > .gitignore <<'EOF'
.env
.env.local
.DS_Store
EOF
      write_readme; write_env_example; write_license
      ;;
  esac

  git add .
  git commit --allow-empty -m "init: bootstrap $PROJECT_NAME"

  if [[ "$PUSH_TO_GITHUB" == true ]]; then
    GH_ARGS=("$OWNER/$PROJECT_NAME" "--$VISIBILITY" "--source=." "--remote=origin" "--push")
    [[ -n "$DESCRIPTION" ]] && GH_ARGS+=("--description" "$DESCRIPTION")

    if ! gum spin --spinner dot --title "  Creating GitHub repo..." -- \
        gh repo create "${GH_ARGS[@]}"; then
      gum style --foreground 196 \
        "  GitHub repo creation failed. Your local repo is intact." \
        "  To retry: gh repo create $OWNER/$PROJECT_NAME --source=$PROJECT_PATH --push"
      PUSH_TO_GITHUB=false   # skip repo URL lookup below
    fi
  fi
fi

# ─── open in editor ───────────────────────────────────────────────────────────
EDITOR_OPTIONS=()
command -v code   &>/dev/null && EDITOR_OPTIONS+=("VS Code")
command -v cursor &>/dev/null && EDITOR_OPTIONS+=("Cursor")
command -v zed    &>/dev/null && EDITOR_OPTIONS+=("Zed")
command -v nvim   &>/dev/null && EDITOR_OPTIONS+=("Neovim")
EDITOR_OPTIONS+=("Skip")

EDITOR_CHOICE=$(printf "%s\n" "${EDITOR_OPTIONS[@]}" | gum choose --header "  Open in editor")

case "$EDITOR_CHOICE" in
  "VS Code")  code   "$PROJECT_PATH" ;;
  "Cursor")   cursor "$PROJECT_PATH" ;;
  "Zed")      zed    "$PROJECT_PATH" ;;
  "Neovim")   nvim   "$PROJECT_PATH" ;;
esac

# ─── done ─────────────────────────────────────────────────────────────────────
REPO_URL=""
if [[ "$PUSH_TO_GITHUB" == true ]]; then
  REPO_URL=$(gh repo view "$OWNER/$PROJECT_NAME" --json url --jq .url 2>/dev/null || true)
fi

echo ""
gum style \
  --foreground 82 --border-foreground 82 --border rounded \
  --padding "0 2" --margin "0 2" \
  "✓ $PROJECT_NAME is ready${REPO_URL:+  →  $REPO_URL}"
echo ""

CD_CMD="cd $PROJECT_PATH"
if command -v pbcopy &>/dev/null; then
  printf "%s" "$CD_CMD" | pbcopy
  gum style --foreground 240 "  $CD_CMD  (copied to clipboard)"
else
  gum style --foreground 240 "  $CD_CMD"
fi
echo ""

# ─── save history ─────────────────────────────────────────────────────────────
printf "%s|%s|%s|%s\n" \
  "$PROJECT_NAME" \
  "$PROJECT_PATH" \
  "${REPO_URL:-}" \
  "$(date '+%Y-%m-%d %H:%M')" \
  >> "$HISTORY_FILE"
