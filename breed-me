# ─── template flow ────────────────────────────────────────────────────────────
if [[ "$STACK" == "From template →" ]]; then
  mkdir -p "$PARENT_DIR"
  cd "$PARENT_DIR"

  GH_ARGS=("$OWNER/$PROJECT_NAME" "--template" "$TEMPLATE_REPO" "--$VISIBILITY" "--clone")
  [[ -n "$DESCRIPTION" ]] && GH_ARGS+=("--description" "$DESCRIPTION")

  if ! gum spin --spinner dot --title "  Cloning from the gene pool..." -- \
      gh repo create "${GH_ARGS[@]}"; then
    die "Cloning failed — bad genes? Check the template repo name and your permissions." \
        "  To retry: gh repo create $OWNER/$PROJECT_NAME --template $TEMPLATE_REPO --$VISIBILITY --clone"
  fi

  cd "$PROJECT_PATH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"

  if [[ "$BRANCH" != "main" ]]; then
    git branch -m "$BRANCH"
    git push origin "$BRANCH"
    gh repo edit "$OWNER/$PROJECT_NAME" --default-branch "$BRANCH" 2>/dev/null || true
  fi

# ─── standard flow ────────────────────────────────────────────────────────────
else
  EXECUTION_STARTED=true
  mkdir -p "$PROJECT_PATH" || die "cannot create '$PROJECT_PATH' — check permissions"
  cd "$PROJECT_PATH"
  git init -q -b "$BRANCH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"

  GO_MODULE="${OWNER:+github.com/$OWNER/}$PROJECT_NAME"
  GO_VERSION="1.23"
  if command -v go &>/dev/null; then
    GO_VERSION=$(go env GOVERSION 2>/dev/null | sed 's/^go//' || echo "1.23")
  fi

  case "$STACK" in
    "Node.js")
      cat > .gitignore <<'EOF'
