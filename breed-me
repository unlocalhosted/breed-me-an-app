#!/usr/bin/env bash
set -euo pipefail

VERSION="0.5.0"

# ─── config ───────────────────────────────────────────────────────────────────
CONFIG_DIR="$HOME/.config/breed-me"
PROFILES_FILE="$CONFIG_DIR/profiles"
HISTORY_FILE="$CONFIG_DIR/history"
LAST_DIR_FILE="$CONFIG_DIR/last_dir"
SELF_REPO="unlocalhosted/breed-me-an-app"
SELF_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

mkdir -p "$CONFIG_DIR"

# ─── cleanup ──────────────────────────────────────────────────────────────────
TMPFILES=()
EXECUTION_STARTED=false
PROJECT_PATH=""

cleanup() {
  rm -f "${TMPFILES[@]}" 2>/dev/null || true
  # Remove partially-scaffolded project on interrupt
  if [[ "$EXECUTION_STARTED" == true && -n "$PROJECT_PATH" && -d "$PROJECT_PATH" ]]; then
    rm -rf "$PROJECT_PATH" 2>/dev/null || true
    printf "\n  Stillborn — cleaned up partial directory: %s\n" "$PROJECT_PATH" >&2
  fi
}
trap cleanup EXIT INT TERM

# ─── helpers ──────────────────────────────────────────────────────────────────
safe_timeout() {
  if command -v timeout &>/dev/null; then timeout "$@"
  elif command -v gtimeout &>/dev/null; then gtimeout "$@"
  else shift; "$@"
  fi
}

# Exit codes: 0=success, 1=general error, 2=missing dependency, 3=user abort, 4=auth failure
die() {
  echo ""
  gum style --foreground 196 "  ✗ $*"
  echo ""
  exit 1
}

warn() {
  gum style --foreground 214 "  ⚠ $*"
}

note() {
  gum style --foreground 240 "  $*"
}

# ─── wizard ───────────────────────────────────────────────────────────────────
# PROGRESS_LINES accumulates "  key   value" entries shown above each prompt.
# show_header clears the screen and redraws the phase header + all progress so
# far — this is what prevents terminal jumping between prompts.
PROGRESS_LINES=()
PENDING_WARNINGS=()

add_progress() {
  PROGRESS_LINES+=("  $(printf '%-14s' "$1")  $2")
}

show_header() {
  clear
  gum style \
    --foreground 212 --border-foreground 212 --border normal \
    --padding "0 2" --margin "0 2" \
    "◆ breed-me  ·  $1"
  if [[ ${#PROGRESS_LINES[@]} -gt 0 ]]; then
    echo ""
    gum style --foreground 240 "${PROGRESS_LINES[@]}"
    echo ""
  fi
  # Re-display any pending warnings that survived a clear
  if [[ ${#PENDING_WARNINGS[@]} -gt 0 ]]; then
    for w in "${PENDING_WARNINGS[@]}"; do
      warn "$w"
    done
    PENDING_WARNINGS=()
    echo ""
  fi
}

# ─── --help ───────────────────────────────────────────────────────────────────
show_help() {
  printf "Usage: breed-me [SUBCOMMAND] [OPTIONS]\n\n"
  printf "Subcommands:\n"
  printf "  list        Show your offspring\n"
  printf "  profiles    Manage saved DNA profiles\n\n"
  printf "Options:\n"
  printf "  --local     Breed locally (no GitHub, no gh required)\n"
  printf "  --dry-run   Preview the litter without breeding anything\n"
  printf "  --update    Evolve to the latest version\n"
  printf "  --version   Show version\n"
  printf "  -h, --help  Show this help\n"
}

# ─── --update ─────────────────────────────────────────────────────────────────
do_update() {
  local tmp
  tmp=$(mktemp); TMPFILES+=("$tmp")
  printf "Evolving breed-me...\n"
  curl -fsSL --max-time 30 \
    "https://raw.githubusercontent.com/$SELF_REPO/main/breed-me" \
    -o "$tmp" || { printf "error: download failed\n" >&2; exit 1; }
  if [[ -w "$SELF_PATH" ]]; then
    install -m 755 "$tmp" "$SELF_PATH"
  elif command -v sudo &>/dev/null; then
    sudo install -m 755 "$tmp" "$SELF_PATH"
  else
    printf "error: cannot write to %s\n  Try: sudo breed-me --update\n" "$SELF_PATH" >&2
    exit 1
  fi
  printf "Done. You've reached peak evolution.\n"
  exit 0
}

# ─── flags + subcommand ───────────────────────────────────────────────────────
FLAG_LOCAL=false
FLAG_DRY_RUN=false
SUBCOMMAND=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --local)    FLAG_LOCAL=true ;;
    --dry-run)  FLAG_DRY_RUN=true ;;
    --update)   do_update ;;
    --version)  printf "breed-me %s\n" "$VERSION"; exit 0 ;;
    -h|--help)  show_help; exit 0 ;;
    list)       SUBCOMMAND="list" ;;
    profiles)   SUBCOMMAND="profiles" ;;
    *)          printf "error: unknown option: %s\n" "$1" >&2; exit 1 ;;
  esac
  shift
done

# ─── dep check ────────────────────────────────────────────────────────────────
install_hint() {
  if command -v brew &>/dev/null; then
    printf "brew install %s" "$1"
  elif command -v apt-get &>/dev/null; then
    case "$1" in
      gum) printf "see https://github.com/charmbracelet/gum#installation" ;;
      gh)  printf "see https://github.com/cli/cli#installation" ;;
      *)   printf "apt-get install %s" "$1" ;;
    esac
  else
    printf "see https://github.com/charmbracelet/gum#installation"
  fi
}

for cmd in git gum; do
  command -v "$cmd" &>/dev/null || {
    printf "error: '%s' is required. %s\n" "$cmd" "$(install_hint "$cmd")" >&2
    exit 2
  }
done
if [[ "$FLAG_LOCAL" == false ]] && ! command -v gh &>/dev/null; then
  printf "error: 'gh' is required for GitHub. %s\n" "$(install_hint gh)" >&2
  printf "       Or use --local to skip GitHub.\n" >&2
  exit 2
fi

# ─── list subcommand ──────────────────────────────────────────────────────────
if [[ "$SUBCOMMAND" == "list" ]]; then
  if [[ ! -f "$HISTORY_FILE" ]] || [[ ! -s "$HISTORY_FILE" ]]; then
    gum style --foreground 240 "  No offspring yet."
    exit 0
  fi
  echo ""
  while IFS='|' read -r pname ppath purl pdate; do
    gum style --foreground 212 "  $pname"
    gum style --foreground 240 \
      "    path  $ppath" \
      "    repo  ${purl:-local}" \
      "    date  $pdate"
    echo ""
  done < "$HISTORY_FILE"
  exit 0
fi

# ─── profiles subcommand ─────────────────────────────────────────────────────
if [[ "$SUBCOMMAND" == "profiles" ]]; then
  if [[ ! -f "$PROFILES_FILE" ]] || [[ ! -s "$PROFILES_FILE" ]]; then
    gum style --foreground 240 "  No DNA on file yet. Supply yours during your first breed-me run."
    exit 0
  fi
  echo ""
  while IFS='|' read -r plabel pname pemail; do
    gum style --foreground 212 "  $plabel"
    gum style --foreground 240 \
      "    name   $pname" \
      "    email  $pemail"
    echo ""
  done < "$PROFILES_FILE"

  ACTION=$(printf "Done\nPurge a DNA profile\n" | gum choose --header "  Action" --height 4)
  if [[ "$ACTION" == "Purge a DNA profile" ]]; then
    DEL_LABEL=$(cut -d'|' -f1 "$PROFILES_FILE" | gum choose --header "  Purge whose DNA?" --height 8)
    if [[ -n "$DEL_LABEL" ]]; then
      awk -F'|' -v l="$DEL_LABEL" '$1 != l' "$PROFILES_FILE" > "${PROFILES_FILE}.tmp" 2>/dev/null || true
      mv "${PROFILES_FILE}.tmp" "$PROFILES_FILE" 2>/dev/null || true
      gum style --foreground 82 "  ✓ Purged DNA: $DEL_LABEL"
    fi
  fi
  exit 0
fi

# ─── prefetch github data ─────────────────────────────────────────────────────
GITHUB_USER=""
GITHUB_ORGS=""

if [[ "$FLAG_LOCAL" == false ]]; then
  PREFETCH_USER=$(mktemp); TMPFILES+=("$PREFETCH_USER")
  PREFETCH_ORGS=$(mktemp); TMPFILES+=("$PREFETCH_ORGS")

  gum spin --spinner dot --title "  Sniffing out GitHub..." -- \
    bash -c '
      safe_timeout() {
        if command -v timeout &>/dev/null; then timeout "$@"
        elif command -v gtimeout &>/dev/null; then gtimeout "$@"
        else shift; "$@"; fi
      }
      safe_timeout 10 gh api user --jq .login > "$1" 2>/dev/null &
      safe_timeout 10 gh api user/orgs --jq ".[].login" > "$2" 2>/dev/null &
      wait
    ' _ "$PREFETCH_USER" "$PREFETCH_ORGS" || true

  if [[ -s "$PREFETCH_USER" ]]; then
    GITHUB_USER=$(<"$PREFETCH_USER")
    GITHUB_ORGS=$(<"$PREFETCH_ORGS")
  fi

  if [[ -z "$GITHUB_USER" ]]; then
    gum style --foreground 196 \
      "  ✗ GitHub won't let us in. Run: gh auth login" \
      "  Or breed locally with --local."
    exit 4
  fi
fi

# ─── first-run welcome ────────────────────────────────────────────────────────
if [[ ! -f "$HISTORY_FILE" ]] && [[ ! -f "$PROFILES_FILE" ]]; then
  clear
  gum style \
    --foreground 212 --border-foreground 212 --border rounded \
    --padding "0 2" --margin "0 2" \
    "◆ Welcome to the breed-me kennel" \
    "" \
    "  Pick the traits, supply the DNA, and we'll breed your app in 4 steps:" \
    "  traits & stack → habitat → DNA → pedigree" \
    "" \
    "  Your DNA is saved as profiles for next time." \
    "  Run breed-me --dry-run to preview the litter without breeding anything."
  echo ""
  gum confirm "  Ready to breed?" || { echo ""; gum style --foreground 240 "  Litter abandoned."; echo ""; exit 3; }
fi

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 1 — PROJECT
# ═══════════════════════════════════════════════════════════════════════════════

show_header "Traits  ·  1 of 4"

# ─── project name ─────────────────────────────────────────────────────────────
PROJECT_NAME_RAW=$(gum input --prompt "  Name your offspring › " --placeholder "my-app")
[[ -z "$PROJECT_NAME_RAW" ]] && die "project name is required — try: my-app"

PROJECT_NAME=$(printf "%s" "$PROJECT_NAME_RAW" \
  | tr '[:upper:]' '[:lower:]' \
  | tr ' _' '-' \
  | tr -cd 'a-z0-9-')

# strip leading/trailing hyphens
PROJECT_NAME="${PROJECT_NAME#"${PROJECT_NAME%%[!-]*}"}"
PROJECT_NAME="${PROJECT_NAME%"${PROJECT_NAME##*[!-]}"}"

# enforce GitHub's 100-char repo name limit
if [[ ${#PROJECT_NAME} -gt 100 ]]; then
  PROJECT_NAME="${PROJECT_NAME:0:100}"
  PROJECT_NAME="${PROJECT_NAME%%-}"
fi

[[ "$PROJECT_NAME" != "$PROJECT_NAME_RAW" ]] && \
  note "Normalized: $PROJECT_NAME_RAW → $PROJECT_NAME"
[[ -z "$PROJECT_NAME" ]] && \
  die "\"$PROJECT_NAME_RAW\" has no valid characters — try: my-app"

add_progress "offspring" "$PROJECT_NAME"

# ─── stack ────────────────────────────────────────────────────────────────────
show_header "Traits  ·  1 of 4"

STACK_OPTIONS=("Node.js" "TypeScript" "Python" "Go" "Rust" "React (Vite)" "Next.js" "Swift Library" "Swift iOS" "Swift macOS" "Swift macOS Launcher" "Bare")
[[ "$FLAG_LOCAL" == false ]] && STACK_OPTIONS+=("From template →")

STACK=$(printf "%s\n" "${STACK_OPTIONS[@]}" | gum choose --header "  Bloodline" --height 15)
add_progress "bloodline" "$STACK"

# ─── template repo ────────────────────────────────────────────────────────────
TEMPLATE_REPO=""
if [[ "$STACK" == "From template →" ]]; then
  show_header "Traits  ·  1 of 4"
  TEMPLATE_REPO=$(gum input --prompt "  GitHub template › " --placeholder "owner/repo")
  [[ -z "$TEMPLATE_REPO" ]] && die "template repo is required — try: owner/repo"
  add_progress "gene pool" "$TEMPLATE_REPO"
fi

# ─── js/ts dep checks ─────────────────────────────────────────────────────────
PNPM_VERSION=""
if [[ "$STACK" == "TypeScript" || "$STACK" == "React (Vite)" || "$STACK" == "Next.js" ]]; then
  command -v pnpm &>/dev/null || \
    die "pnpm is required for $STACK — install from pnpm.io or: npm install -g pnpm"
  PNPM_VERSION=$(pnpm --version 2>/dev/null || echo "latest")
fi
if [[ "$STACK" == "React (Vite)" || "$STACK" == "Next.js" ]]; then
  command -v node &>/dev/null || \
    die "Node.js is required for $STACK — install from nodejs.org"
fi
if [[ "$STACK" == "TypeScript" ]]; then
  command -v bun &>/dev/null || \
    die "bun is required for $STACK — install from bun.sh or: curl -fsSL https://bun.sh/install | bash"
fi

# ─── rust dep check ───────────────────────────────────────────────────────────
if [[ "$STACK" == "Rust" ]]; then
  command -v cargo &>/dev/null || \
    die "cargo is required for Rust — install from rustup.rs or: curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
fi

# ─── swift dep checks ─────────────────────────────────────────────────────────
SWIFT_TYPE_NAME=""
if [[ "$STACK" == "Swift Library" || "$STACK" == "Swift iOS" || \
      "$STACK" == "Swift macOS" || "$STACK" == "Swift macOS Launcher" ]]; then
  xcrun swift --version &>/dev/null 2>&1 || \
    die "Xcode is required for Swift — install from the App Store or developer.apple.com"
  SWIFT_TYPE_NAME=$(printf "%s" "$PROJECT_NAME" | \
    awk 'BEGIN{FS="-";OFS=""}{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2)}1')
fi

# ─── tuist dep check for app stacks ──────────────────────────────────────────
if [[ "$STACK" == "Swift iOS" || "$STACK" == "Swift macOS" || \
      "$STACK" == "Swift macOS Launcher" ]]; then
  command -v tuist &>/dev/null || \
    die "Tuist is required for $STACK — install: brew install tuist"
fi

# ─── bundle id for swift stacks ──────────────────────────────────────────────
BUNDLE_ID=""
if [[ "$STACK" == "Swift iOS" || "$STACK" == "Swift macOS" || \
      "$STACK" == "Swift macOS Launcher" ]]; then
  if [[ -n "$GITHUB_USER" ]]; then
    BUNDLE_ID="io.github.$GITHUB_USER.$PROJECT_NAME"
  else
    BUNDLE_ID="com.example.$PROJECT_NAME"
  fi
fi

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 2 — GITHUB
# ═══════════════════════════════════════════════════════════════════════════════

PUSH_TO_GITHUB=false
OWNER="${GITHUB_USER}"
VISIBILITY="private"
DESCRIPTION=""

show_header "Habitat  ·  2 of 4"

if [[ "$FLAG_LOCAL" == true ]]; then
  add_progress "habitat" "local only"
elif [[ "$STACK" == "From template →" ]]; then
  # template always pushes to GitHub
  PUSH_TO_GITHUB=true
  if [[ -n "$GITHUB_ORGS" ]]; then
    OWNER=$(printf "%s\n%s\n" "$GITHUB_USER" "$GITHUB_ORGS" | gum choose --header "  Keeper" --height 8)
    add_progress "keeper" "$OWNER"
    show_header "Habitat  ·  2 of 4"
  fi
  VISIBILITY=$(gum choose --header "  Visibility" --height 4 "private" "public")
  add_progress "habitat" "$OWNER / $VISIBILITY"
else
  gum confirm "  Push to GitHub?" && PUSH_TO_GITHUB=true || true

  if [[ "$PUSH_TO_GITHUB" == true ]]; then
    if [[ -n "$GITHUB_ORGS" ]]; then
      show_header "Habitat  ·  2 of 4"
      OWNER=$(printf "%s\n%s\n" "$GITHUB_USER" "$GITHUB_ORGS" | gum choose --header "  Keeper" --height 8)
      add_progress "keeper" "$OWNER"
    fi
    show_header "Habitat  ·  2 of 4"
    VISIBILITY=$(gum choose --header "  Visibility" --height 4 "private" "public")
    add_progress "habitat" "$OWNER / $VISIBILITY"
  else
    add_progress "habitat" "local only"
  fi
fi

show_header "Habitat  ·  2 of 4"
DESCRIPTION=$(gum input --prompt "  Description (optional) › " --placeholder "What will this creature do?")
[[ -n "$DESCRIPTION" ]] && add_progress "description" "$DESCRIPTION"

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 3 — IDENTITY
# ═══════════════════════════════════════════════════════════════════════════════

show_header "DNA  ·  3 of 4"

save_profile() {
  local label="${1//|/}" name="$2" email="$3"
  awk -F'|' -v l="$label" '$1 != l' "$PROFILES_FILE" > "${PROFILES_FILE}.tmp" 2>/dev/null || true
  mv "${PROFILES_FILE}.tmp" "$PROFILES_FILE" 2>/dev/null || true
  printf "%s|%s|%s\n" "$label" "$name" "$email" >> "$PROFILES_FILE"
}

load_profile() {
  local label="$1" line
  line=$(awk -F'|' -v l="$label" '$1 == l {print; exit}' "$PROFILES_FILE" 2>/dev/null || true)
  GIT_NAME=$(cut -d'|' -f2 <<< "$line")
  GIT_EMAIL=$(cut -d'|' -f3 <<< "$line")
}

GIT_NAME=""
GIT_EMAIL=""

if [[ -f "$PROFILES_FILE" ]] && [[ -s "$PROFILES_FILE" ]]; then
  PROFILE_CHOICE=$(
    { cut -d'|' -f1 "$PROFILES_FILE"; printf "+ New DNA\n"; } \
    | gum choose --header "  Whose DNA?" --height 8
  )
  if [[ "$PROFILE_CHOICE" == "+ New DNA" ]]; then
    show_header "DNA  ·  3 of 4"
    GIT_NAME=$(gum input --prompt "  git user.name › " --placeholder "Your Name")
    show_header "DNA  ·  3 of 4"
    GIT_EMAIL=$(gum input --prompt "  git user.email › " --placeholder "you@example.com")
    show_header "DNA  ·  3 of 4"
    PROFILE_LABEL=$(gum input --prompt "  Save as (optional) › " --placeholder "work / personal")
    PROFILE_LABEL="${PROFILE_LABEL//|/}"
    [[ -n "$PROFILE_LABEL" ]] && save_profile "$PROFILE_LABEL" "$GIT_NAME" "$GIT_EMAIL"
  else
    load_profile "$PROFILE_CHOICE"
  fi
else
  GIT_NAME=$(gum input --prompt "  git user.name › " --placeholder "Your Name")
  show_header "DNA  ·  3 of 4"
  GIT_EMAIL=$(gum input --prompt "  git user.email › " --placeholder "you@example.com")
  show_header "DNA  ·  3 of 4"
  PROFILE_LABEL=$(gum input --prompt "  Save as (optional) › " --placeholder "work / personal")
  PROFILE_LABEL="${PROFILE_LABEL//|/}"
  [[ -n "$PROFILE_LABEL" ]] && save_profile "$PROFILE_LABEL" "$GIT_NAME" "$GIT_EMAIL"
fi

[[ -z "$GIT_NAME" ]]  && die "git user.name is required"
[[ -z "$GIT_EMAIL" ]] && die "git user.email is required"
add_progress "DNA" "$GIT_NAME <$GIT_EMAIL>"

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 4 — DETAILS
# ═══════════════════════════════════════════════════════════════════════════════

show_header "Pedigree  ·  4 of 4"

# ─── license ──────────────────────────────────────────────────────────────────
LICENSE="None"
if [[ "$STACK" != "From template →" ]]; then
  LICENSE=$(gum choose --header "  License" --height 6 "MIT" "Apache 2.0" "GPL-3.0" "None")
  add_progress "license" "$LICENSE"
fi

# ─── branch name ──────────────────────────────────────────────────────────────
while true; do
  show_header "Pedigree  ·  4 of 4"
  BRANCH=$(gum input --prompt "  Default branch › " --value "main")
  BRANCH="${BRANCH:-main}"
  if [[ "$BRANCH" =~ \.\. ]] \
     || [[ "$BRANCH" =~ [[:space:]] ]] \
     || [[ ! "$BRANCH" =~ ^[a-zA-Z0-9/_.-]+$ ]]; then
    gum style --foreground 196 "  Invalid — use letters, numbers, /, _, -, . and no '..'"
  else
    break
  fi
done
add_progress "branch" "$BRANCH"

# ─── .env.example ─────────────────────────────────────────────────────────────
ADD_ENV=false
if [[ "$STACK" != "From template →" && ! "$STACK" =~ ^Swift ]]; then
  show_header "Pedigree  ·  4 of 4"
  gum style --foreground 240 "  Creates .env.example as a template for environment variables."
  echo ""
  gum confirm "  Add .env.example?" && ADD_ENV=true || true
  add_progress "env.example" "$(if $ADD_ENV; then printf yes; else printf no; fi)"
fi

# ─── github actions ci ────────────────────────────────────────────────────────
ADD_CI=false
if [[ "$STACK" != "From template →" ]] && [[ "$STACK" != "Bare" ]]; then
  show_header "Pedigree  ·  4 of 4"
  gum style --foreground 240 "  Writes .github/workflows/ci.yml — build + test on push and PR."
  echo ""
  gum confirm "  Add GitHub Actions CI?" && ADD_CI=true || true
  add_progress "ci" "$(if $ADD_CI; then printf yes; else printf no; fi)"
fi

# ─── swiftlint advisory ───────────────────────────────────────────────────────
if [[ "$STACK" =~ ^Swift ]] && ! command -v swiftlint &>/dev/null; then
  show_header "Pedigree  ·  4 of 4"
  note "swiftlint not found — .swiftlint.yml will be written but linting"
  note "won't run in CI until you install it: brew install swiftlint"
  echo ""
fi

# ─── parent directory ─────────────────────────────────────────────────────────
DEFAULT_DIR="$HOME"
if [[ -f "$LAST_DIR_FILE" ]]; then
  SAVED_DIR=$(cat "$LAST_DIR_FILE")
  [[ -d "$SAVED_DIR" ]] && DEFAULT_DIR="$SAVED_DIR"
fi

show_header "Pedigree  ·  4 of 4"
gum style --foreground 240 "  Where should $PROJECT_NAME live? Pick a parent folder."
echo ""
PARENT_DIR=$(gum file --directory --file=false \
  --height 8 --show-help \
  --header "  Nesting ground  (enter = select · esc = cancel)" \
  "$DEFAULT_DIR") || die "no directory selected"
[[ -z "$PARENT_DIR" ]] && die "no directory selected"
PARENT_DIR="${PARENT_DIR%/}"
printf "%s\n" "$PARENT_DIR" > "${LAST_DIR_FILE}.tmp" && mv "${LAST_DIR_FILE}.tmp" "$LAST_DIR_FILE"

PROJECT_PATH="$PARENT_DIR/$PROJECT_NAME"
add_progress "nest" "$PROJECT_PATH"

# ═══════════════════════════════════════════════════════════════════════════════
# READY
# ═══════════════════════════════════════════════════════════════════════════════

show_header "Ready to breed"

# Enhanced summary with borders for the confirmation screen
gum style --border rounded --border-foreground 212 \
  --padding "0 2" --margin "0 2" \
  "${PROGRESS_LINES[@]}"
echo ""

if [[ "$FLAG_DRY_RUN" == true ]]; then
  gum style --foreground 214 --border rounded --border-foreground 214 \
    --padding "0 2" --margin "0 2" \
    "--dry-run: no offspring were harmed."
  echo ""
  exit 0
fi

gum confirm "  Breed it?" || { echo ""; gum style --foreground 240 "  Litter abandoned."; echo ""; exit 3; }
echo ""

# ─── guard ────────────────────────────────────────────────────────────────────
if [[ -d "$PROJECT_PATH" ]]; then
  die "'$PROJECT_PATH' already lives here — pick a different name or directory"
fi

# ─── write helpers ────────────────────────────────────────────────────────────
YEAR=$(date +%Y)
LICENSE_SPDX="${LICENSE/None/UNLICENSED}"
LICENSE_SPDX="${LICENSE_SPDX/ /-}"
JSON_DESCRIPTION="${DESCRIPTION//\\/\\\\}"
JSON_DESCRIPTION="${JSON_DESCRIPTION//\"/\\\"}"

write_readme() {
  cat > README.md <<EOF
# $PROJECT_NAME

${DESCRIPTION:-}

## Development
EOF
  case "$STACK" in
    "Node.js")
      cat >> README.md <<'EOF'

```sh
npm run dev      # start with --watch
npm test         # run tests
```
EOF
      ;;
    "TypeScript")
      cat >> README.md <<'EOF'

```sh
pnpm dev         # start with bun --watch
pnpm test        # run tests (vitest)
pnpm lint        # lint (oxlint)
pnpm build       # type-check
```
EOF
      ;;
    "Python")
      cat >> README.md <<'EOF'

```sh
python -m venv .venv && source .venv/bin/activate
pip install -r requirements.txt
python main.py   # run the app
pytest           # run tests
```
EOF
      ;;
    "Go")
      cat >> README.md <<'EOF'

```sh
go run .          # run the app
go test ./...     # run tests
go build ./...    # build
```
EOF
      ;;
    "Rust")
      cat >> README.md <<'EOF'

```sh
cargo run         # run the app
cargo test        # run tests
cargo build       # build
```
EOF
      ;;
    "React (Vite)")
