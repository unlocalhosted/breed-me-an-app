}

write_ci() {
  $ADD_CI || return 0
  mkdir -p .github/workflows
  case "$STACK" in
    "Node.js")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 20 }
      - run: npm install
      - run: npm test --if-present
EOF
      ;;
    "TypeScript")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        with:
          version: latest
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm lint
      - run: pnpm test:run
      - run: pnpm build
EOF
      ;;
    "Python")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: "3.12" }
      - run: pip install -r requirements.txt
      - run: python -m pytest --tb=short -q
EOF
      ;;
    "Go")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with: { go-version: stable }
      - run: go build ./...
      - run: go test ./...
EOF
      ;;
    "Rust")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
      - run: cargo build
      - run: cargo test
EOF
      ;;
    "React (Vite)"|"Next.js")
      cat > .github/workflows/ci.yml <<EOF
name: CI
on:
  push:
    branches: [$BRANCH]
  pull_request:
jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        with:
          version: latest
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm lint
      - run: pnpm test:run
      - run: pnpm build
EOF
      ;;
  esac
}

# ─── template flow ────────────────────────────────────────────────────────────
if [[ "$STACK" == "From template →" ]]; then
  mkdir -p "$PARENT_DIR"
  cd "$PARENT_DIR"

  GH_ARGS=("$OWNER/$PROJECT_NAME" "--template" "$TEMPLATE_REPO" "--$VISIBILITY" "--clone")
  [[ -n "$DESCRIPTION" ]] && GH_ARGS+=("--description" "$DESCRIPTION")

  gum spin --spinner dot --title "  Creating from template..." -- \
    gh repo create "${GH_ARGS[@]}"

  cd "$PROJECT_PATH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"

  if [[ "$BRANCH" != "main" ]]; then
    git branch -m "$BRANCH"
    git push origin "$BRANCH"
    gh repo edit "$OWNER/$PROJECT_NAME" --default-branch "$BRANCH" 2>/dev/null || true
  fi

# ─── standard flow ────────────────────────────────────────────────────────────
else
  mkdir -p "$PROJECT_PATH" || die "cannot create '$PROJECT_PATH' — check permissions"
  cd "$PROJECT_PATH"
  git init -q -b "$BRANCH"
  git config user.name  "$GIT_NAME"
  git config user.email "$GIT_EMAIL"

  GO_MODULE="${OWNER:+github.com/$OWNER/}$PROJECT_NAME"

  case "$STACK" in
    "Node.js")
      cat > .gitignore <<'EOF'
node_modules/
dist/
.env
.env.local
*.log
.DS_Store
EOF
      cat > package.json <<EOF
{
  "name": "$PROJECT_NAME",
  "version": "0.1.0",
  "description": "$JSON_DESCRIPTION",
  "main": "index.js",
  "scripts": {
    "start": "node index.js"
  },
  "license": "$LICENSE_SPDX"
}
EOF
      touch index.js
      write_readme; write_env_example; write_license; write_ci
      ;;

    "TypeScript")
      cat > .gitignore <<'EOF'
node_modules/
dist/
.env
.env.local
*.log
.DS_Store
EOF
      cat > package.json <<EOF
{
  "name": "$PROJECT_NAME",
  "version": "0.1.0",
  "description": "$JSON_DESCRIPTION",
  "type": "module",
  "packageManager": "pnpm@latest",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "devDependencies": {
    "@types/bun": "latest",
